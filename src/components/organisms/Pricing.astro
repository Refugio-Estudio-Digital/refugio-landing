---
const tiers = [
	{
		slug: 'refugio',
		nombre: 'El Refugio',
		nivel: 'Nivel 1',
		tagline: 'Tu puerta de entrada al mundo digital con elegancia y sencillez.',
		features: [
			'Web de página única (Landing)',
			'Presencia profesional en Google',
			'Carga instantánea en móviles',
		],
		cta: 'Consultar',
		href: 'https://wa.me/+5492944212964?text=Hola!%20Vi%20la%20web%20de%20Refugio%20y%20me%20interesó%20el%20Nivel%201:%20El%20Refugio.%20¿Me%20contás%20más?',
		destacado: false,
	},
	{
		slug: 'ascenso',
		nombre: 'El Ascenso',
		nivel: 'Nivel 2',
		tagline:
			'Tu propia casa digital. Autonomía total para crecer sin depender de nadie.',
		features: [
			'Sitio multipágina completo',
			'Panel de gestión desde el celular',
			'Estrategia de posicionamiento local',
			'Gestión de reservas o catálogo',
		],
		cta: 'Empezar',
		href: 'https://wa.me/+5492944212964?text=Hola!%20Me%20gustaría%20iniciar%20el%20Nivel%202:%20El%20Ascenso%20para%20mi%20proyecto.%20¿Cómo%20podemos%20arrancar?',
		destacado: true,
	},
	{
		slug: 'cima',
		nombre: 'La Cima',
		nivel: 'Nivel 3',
		tagline: 'Soluciones a medida para proyectos que no conocen fronteras.',
		features: [
			'Sistemas de gestión personalizados',
			'Automatización de procesos',
			'Acompañamiento estratégico Pro',
		],
		cta: 'Contactar',
		href: 'https://wa.me/+5492944212964?text=Hola!%20Tengo%20un%20proyecto%20grande%20en%20mente%20y%20creo%20que%20necesito%20el%20Nivel%203:%20La%20Cima.%20¿Podemos%20coordinar%20una%20charla?',
		destacado: false,
	},
];
---

<section class="py-24 px-6 bg-background-950" data-animate>
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-16 space-y-3">
			<h2
				id="pricing"
				class="text-4xl md:text-5xl font-lora font-bold text-text-100"
			>
				Rutas de Ascenso
			</h2>
			<p class="text-text-400 max-w-xl mx-auto text-lg">
				Cada proyecto tiene su propio ritmo. Elegí el nivel de acompañamiento
				que mejor se adapte a tu momento actual.
			</p>
		</div>

		<div class="grid md:grid-cols-3 gap-6 items-stretch">
			{
				tiers.map((tier) => (
					<div
						class:list={[
							' p-8 flex flex-col gap-6 relative',
							tier.destacado
								? 'bg-background border-2 border-primary shadow-2xl shadow-primary/10 md:-mt-4 md:-mb-4'
								: 'bg-background-900 border border-background-700',
						]}
					>
						{tier.destacado && (
							<div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-primary-900 px-4 py-1  text-xs font-bold tracking-widest uppercase whitespace-nowrap">
								Recomendado
							</div>
						)}

						<div class="space-y-2">
							<h3 class="text-2xl font-lora font-bold text-primary">
								{tier.nombre}
							</h3>
							<p class="text-text-400 text-sm italic">{tier.tagline}</p>
							<p
								class:list={[
									'text-3xl font-bold',
									tier.destacado ? 'text-text-100' : 'text-text-300',
								]}
							>
								{tier.nivel}
							</p>
						</div>

						<ul class="space-y-3 flex-1">
							{tier.features.map((f) => (
								<li class="flex items-start gap-3 text-sm text-text-400">
									<span class="text-primary mt-0.5 shrink-0">✓</span>
									<span>{f}</span>
								</li>
							))}
						</ul>

						<a
							href={tier.href}
							class:list={[
								'w-full text-center px-6 py-3  font-semibold text-sm transition-colors',
								tier.destacado
									? 'bg-primary text-primary-900 hover:bg-primary/80'
									: 'border border-primary text-primary hover:bg-primary/10',
							]}
						>
							{tier.cta}
						</a>
					</div>
				))
			}
		</div>
	</div>
</section>

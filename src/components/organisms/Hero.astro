---
import { Button } from '@/components/ui/button';
---

<section
	class="min-h-screen flex flex-col items-center justify-center px-4 py-20 text-center"
>
	<div class="max-w-3xl space-y-8">
		<h1
			class="text-5xl md:text-7xl font-lora font-bold text-balance leading-tight text-accent"
		>
			Elegancia es claridad.
		</h1>
		<p class="text-xl md:text-2xl text-muted-foreground leading-relaxed">
			Infraestructura digital de alto rendimiento para marcas con identidad.
		</p>
		<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
			Construimos sitios web que cargan al instante, diseñados en Bariloche para
			conectar con el mundo.
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
			<Button asChild size="lg">
				<a
					href="https://wa.link/lg5kqo"
					class="btn btn--default btn--lg bg-primary text-primary-900 hover:cursor-pointer hover:bg-primary/80"
					>Empezar proyecto</a
				>
			</Button>
			<Button asChild>
				<a
					class="btn btn--outline btn--lg border-primary text-primary hover:cursor-pointer hover:bg-primary/10 bg-transparent"
					href="#pricing"
				>
					Más información
				</a>
			</Button>
		</div>
	</div>
</section>

---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const casos = await getCollection('casos');
---

{
	casos.length > 0 && (
		<section class="py-24 px-6 bg-background-950" data-animate>
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16 space-y-3">
					<h2 class="text-4xl md:text-5xl font-lora font-bold text-text-100">
						Casos de Éxito
					</h2>
					<p class="text-text-400 text-lg max-w-xl mx-auto">
						Proyectos reales, resultados concretos.
					</p>
				</div>

				<div class="grid md:grid-cols-2 gap-8">
					{casos.map((caso) => (
						<article class="bg-background overflow-hidden border border-background-800 flex flex-col">
							{caso.data.image ? (
								<Image
									src={caso.data.image}
									alt={caso.data.title}
									class="w-full aspect-video object-cover"
									widths={[400, 800]}
									sizes="(min-width: 768px) 50vw, 100vw"
								/>
							) : (
								<div class="w-full aspect-video bg-gradient-to-br from-background-800 to-primary-950 flex items-center justify-center">
									<span class="text-primary-700 text-5xl font-lora italic">
										R
									</span>
								</div>
							)}

							<div class="p-8 flex flex-col flex-1 gap-4">
								<div class="space-y-2">
									<h3 class="text-2xl font-lora font-bold text-text-100">
										{caso.data.title}
									</h3>
									<p class="text-primary italic text-sm">{caso.data.tagline}</p>
								</div>

								<p class="text-text-400 leading-relaxed text-sm flex-1">
									{caso.data.description}
								</p>

								{caso.data.url && (
									<a
										href={caso.data.url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-primary text-sm font-semibold hover:text-primary/80 transition-colors self-start"
									>
										Conocer proyecto →
									</a>
								)}
							</div>
						</article>
					))}
				</div>
			</div>
		</section>
	)
}
